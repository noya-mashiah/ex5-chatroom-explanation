<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - ChatApp</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom styles -->
    <style>
        body {
            background-color: #FFE3F0;
            min-height: 100vh;
            padding: 20px 0;
        }
        .content-wrapper {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }
        .welcome-banner {
            text-align: center;
            margin-bottom: 2rem;
        }
        .welcome-banner img {
            max-height: 550px;
            width: auto;
        }
        .login-container {
            width: 100%;
        }
        .card {
            border: none;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }
        .alert {
            margin-bottom: 1rem;
        }
        .register-link {
            text-align: center;
            margin-top: 1.5rem;
        }
        .copyright {
            text-align: center;
            margin-top: 2rem;
            color: #6c757d;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="content-wrapper">
        <!-- Welcome Banner -->
        <div class="welcome-banner">
            <img src="/images/chatroom_pic.PNG"
                 alt="Welcome to my chatroom"
                 class="img-fluid">
        </div>

        <!-- Main Content Container -->
        <main class="login-container">

            <!-- Login Form Card -->
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title text-center mb-4">Please sign in</h2>

                    <!-- Success Message -->
                    <% if (successMessage) { %>
                        <div class="alert alert-success text-center" role="alert">
                            <%= successMessage %>
                        </div>
                    <% } %>
                    
                    <!-- Error Message -->
                    <% if (error) { %>
                        <div class="alert alert-danger" role="alert">
                            <%= error %>
                        </div>
                    <% } %>

                    <!-- Login Form -->
                    <form method="POST" action="/login" id="loginForm">
                        <!-- Email Field -->
                        <div class="mb-3">
                            <label for="email" class="form-label">Email address</label>
                            <input
                                    type="email"
                                    class="form-control"
                                    id="email"
                                    name="email"
                                    maxlength="32"
                                    required
                                    autocomplete="email">  
                        </div>

                        <!-- Password Field -->
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input
                                    type="password"
                                    class="form-control"
                                    id="password"
                                    name="password"
                                    maxlength="32"
                                    required
                                    autocomplete="current-password">
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary w-100">Sign in</button>
                    </form>

                    <!-- Registration Link -->
                    <div class="register-link">
                        <span class="text-muted">Don't have an account?</span>
                        <a href="/register" class="btn btn-link">Register</a>
                    </div>
                </div>
            </div>

            <!-- Copyright -->
            <div class="copyright">
                © SK
            </div>
        </main>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Login page functionality -->
    <script src="/javascripts/login.js"></script>
</body>
</html>
